// Config.xcconfig — copy to Config.xcconfig (gitignored) and fill in your values.
// Supabase: https://app.supabase.com → Project Settings → API
//   - SUPABASE_HOST = hostname only from Project URL (e.g. abc.supabase.co), no https://
//   - SUPABASE_ANON_KEY = "anon" "public" JWT (long string with two dots)
// If Google/Apple sign-in works but you see "Invalid API key", the host and anon key
// must be from the same project and freshly copied; then Clean Build Folder and reinstall.
// Google iOS client: https://console.cloud.google.com → APIs & Services → Credentials
SUPABASE_HOST = your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-supabase-anon-key
GOOGLE_CLIENT_ID = your-google-client-id.apps.googleusercontent.com
